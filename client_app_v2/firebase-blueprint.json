{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "location": { "type": "string", "description": "The user's preferred location (ZIP or City)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "ShoppingList": {
      "title": "Shopping List",
      "description": "A list of items to compare prices for.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the list." },
        "userId": { "type": "string", "description": "The owner of the list." },
        "name": { "type": "string", "description": "The name of the list." },
        "items": { "type": "array", "items": { "type": "string" }, "description": "The list of items." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." },
        "updatedAt": { "type": "number", "description": "Timestamp of last update." }
      },
      "required": ["id", "userId", "name", "items"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/users/{userId}/lists/{listId}": {
      "schema": "ShoppingList",
      "description": "User's shopping lists."
    }
  }
}
